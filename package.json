{
  "name": "microsaas-discovery",
  "version": "1.0.0",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "description": "Pipeline multi-agente de descoberta de micro-SaaS via comentários YouTube",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/orchestrator.ts",
    "dev:now": "tsx src/orchestrator.ts --now",
    "schedule": "tsx src/scheduler.ts",
    "smoke": "tsx tests/smoke.ts",
    "test:mcp:youtube": "tsx tests/mcp/youtube.test.ts",
    "test:agent:scraper": "tsx tests/agents/scraper.test.ts",
    "test": "npm run smoke",
    "dashboard": "tsx src/dashboard-server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
